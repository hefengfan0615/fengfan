{
  "buildCommand": null,
  "outputDirectory": "xqwlight",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/pikafish.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.wasm",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    }
  ]
}